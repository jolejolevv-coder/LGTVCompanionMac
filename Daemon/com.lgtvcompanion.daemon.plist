<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.lgtvcompanion.daemon</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/LGTV Companion.app/Contents/Library/LoginItems/LGTV Companion Daemon.app/Contents/MacOS/LGTV Companion Daemon</string>
    </array>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    
    <key>StandardOutPath</key>
    <string>/tmp/com.lgtvcompanion.daemon.log</string>
    
    <key>StandardErrorPath</key>
    <string>/tmp/com.lgtvcompanion.daemon.error.log</string>
    
    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
